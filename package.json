{
  "name": "autodiagram",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "npm run build --silent && node dist/apps/cli/src/index.js generate",
    "layout:init": "npm run build --silent && node dist/apps/cli/src/index.js layout:init",
    "test": "npm run build --silent && node dist/tests/run-tests.js",
    "web:build": "vite build --config apps/web/vite.config.ts",
    "web:dev": "vite --config apps/web/vite.config.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "fast-xml-parser": "^5.7.3",
    "typescript": "^5.4.5",
    "vite": "^8.0.11"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
